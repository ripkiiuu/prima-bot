# =============================================
# .env.example - Salin file ini menjadi .env
# lalu isi dengan nilai asli Anda.
# JANGAN commit file .env ke Git!
# =============================================

# Nomor WA bot (opsional, untuk filter pesan dari diri sendiri)
BOT_NUMBER=

# Admin yang berhak menjalankan perintah sensitif (pisahkan koma jika lebih dari 1)
ADMINS=

# Groq AI (fallback cepat, gratis) - 14.400 req/hari
# Daftar di: https://console.groq.com
GROQ_API_KEY=

# Google Gemini AI - https://aistudio.google.com/
GEMINI_API_KEY=

# OpenAI (prioritas utama kualitas jawaban) - https://platform.openai.com/
OPENAI_API_KEY=

# OpenRouter (opsional) - satu key untuk banyak provider/model
# Daftar di: https://openrouter.ai/
OPENROUTER_API_KEY=

# Urutan fallback provider untuk /ai
# Nilai valid: openai, gemini, openrouter, groq
AI_PROVIDER_ORDER=openai,gemini,openrouter,groq

# Model chain OpenAI (paling pintar -> ringan)
OPENAI_MODELS=gpt-4.1,gpt-4o,gpt-4o-mini
# Kompatibilitas lama (boleh kosong jika pakai OPENAI_MODELS)
OPENAI_MODEL=gpt-4.1

# Model chain Gemini
GEMINI_MODELS=gemini-2.5-pro,gemini-2.0-flash,gemini-1.5-flash-latest
# Kompatibilitas lama (boleh kosong jika pakai GEMINI_MODELS)
GEMINI_MODEL=gemini-2.5-pro

# Model chain OpenRouter
OPENROUTER_MODELS=openai/gpt-4.1,anthropic/claude-3.7-sonnet,google/gemini-2.5-pro,x-ai/grok-4

# Model chain Groq (fallback terakhir)
GROQ_MODELS=llama-3.3-70b-versatile,llama-3.1-70b-versatile
# Kompatibilitas lama (boleh kosong jika pakai GROQ_MODELS)
GROQ_MODEL=llama-3.3-70b-versatile

# OpenWeatherMap - https://openweathermap.org/api (gratis)
OPENWEATHER_API_KEY=

# OCR.space - https://ocr.space/ocrapi (gratis 25k req/bulan)
OCR_API_KEY=helloworld

# Optional deployment config untuk server Linux / Oracle VM
WWEBJS_CLIENT_ID=wa-bot-premium
WWEBJS_DATA_PATH=.wwebjs_auth
PUPPETEER_EXECUTABLE_PATH=
PUPPETEER_HEADLESS=true
